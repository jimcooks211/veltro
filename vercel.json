{
  "headers": [
    {
      "source": "/veltro_signed.mobileconfig",
      "headers": [
        { "key": "Content-Type", "value": "application/x-apple-aspen-config" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"veltro_signed.mobileconfig\"" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/veltro_signed.mobileconfig",
      "destination": "/veltro_signed.mobileconfig"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
